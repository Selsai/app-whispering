<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Whispering | About</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>

  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>

  <nav class="menu">
    <ul>
      <li><a href="/">Whispering</a></li>
      <li class="nav-right">
        <a href="/about" class="menu-link-about">About</a>
        <button class="dark-toggle" id="darkToggle" title="Toggle dark mode">🌙</button>
      </li>
    </ul>
  </nav>

  <div class="page-wrap">
    <div class="about-hero">
      <div class="about-image-col">
        <div class="image-frame">
          <img src="people.png" alt="Women working together in a Parisian café">
        </div>
      </div>
      <div class="about-text-col">
        <div class="section-tag">✦ Our story</div>
        <h1 class="about-title">Welcome to<br><em>Whispering</em></h1>
        <p class="about-desc">
          A microblogging platform that allows you to share your thoughts
          with the world and learn Node.js on the way. Simple, beautiful,
          and made with love. 🌸
        </p>
      </div>
    </div>

    <div class="divider">
      <div class="divider-line"></div>
      <div class="divider-dots">
        <span></span><span></span><span></span>
      </div>
      <div class="divider-line"></div>
    </div>

    <div class="section-title">Community live ⚡</div>

    <div class="stats-grid">
      <div class="stat-card">
        <span class="stat-number"><%= whispers.length %></span>
        <span class="stat-label">Whispers shared</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">∞</span>
        <span class="stat-label">Stories to tell</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">1</span>
        <span class="stat-label">Community</span>
      </div>
    </div>
  </div>

  <script>
    // Dark mode — même logique que index
    const darkToggle = document.getElementById('darkToggle')
    const root = document.documentElement
    const applyTheme = (theme) => {
      root.setAttribute('data-theme', theme)
      darkToggle.textContent = theme === 'dark' ? '☀️' : '🌙'
      localStorage.setItem('theme', theme)
    }
    applyTheme(localStorage.getItem('theme') || 'light')
    darkToggle.addEventListener('click', () => {
      applyTheme(root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark')
    })
  </script>
</body>
</html>